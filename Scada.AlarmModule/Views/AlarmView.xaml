<UserControl x:Class="Scada.AlarmModule.Views.AlarmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="Azure">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- 工具栏-->
        <Border Grid.Row="0" Background="#252526"
                BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4"
                Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="全部确认" Command="{Binding
AckAllCommand}" Background="#007ACC" Foreground="White"
                        Padding="15,5" Margin="0,0,10,0"
                        BorderThickness="0" />
                <Button Content="导出历史" Command="{Binding
ExportCommand}" Background="#3F3F46" Foreground="White"
                        Padding="15,5" BorderThickness="0" />
                <TextBlock Text="活动报警数: "
                           VerticalAlignment="Center" Margin="20,0,5,0" Foreground="Gray" />
                <TextBlock Text="{Binding ActiveAlarmCount}"
                           VerticalAlignment="Center" Foreground="#FF6B6B" FontWeight="Bold"
                           FontSize="14" />
            </StackPanel>
        </Border>
        <!-- 实时报警-->
        <Border Grid.Row="1" Background="#252526"
                BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4"
                Margin="0,0,0,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Background="#2D2D30">
                    <TextBlock Text="实时报警" Margin="10,0"
                               VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF6B6B" />
                </Border>
                <DataGrid Grid.Row="1" ItemsSource="{Binding
ActiveAlarms}" AutoGenerateColumns="False"
                          Background="Transparent"
                          RowBackground="#252526" AlternatingRowBackground="#2D2D30"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="时间"
                                            Binding="{Binding TriggerTime, StringFormat='HH:mm:ss'}" Width="100" />
                        <DataGridTextColumn Header="位号"
                                            Binding="{Binding TagName}" Width="120" />
                        <DataGridTextColumn Header="报警信息"
                                            Binding="{Binding Message}" Width="*" />
                        <DataGridTextColumn Header="级别"
                                            Binding="{Binding Level}" Width="80" />
                        <DataGridTextColumn Header="当前值"
                                            Binding="{Binding ActualValue}" Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
        <!-- 历史报警-->
        <Border Grid.Row="2" Background="#252526"
                BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4"
                Margin="0,5,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Background="#2D2D30">
                    <TextBlock Text="历史报警" Margin="10,0"
                               VerticalAlignment="Center" FontWeight="Bold" />
                </Border>
                <DataGrid Grid.Row="1" ItemsSource="{Binding
HistoryAlarms}" AutoGenerateColumns="False"
                          Background="Transparent"
                          RowBackground="#252526" AlternatingRowBackground="#2D2D30"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="触发时间"
                                            Binding="{Binding TriggerTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                            Width="150" />
                        <DataGridTextColumn Header="位号"
                                            Binding="{Binding TagName}" Width="120" />
                        <DataGridTextColumn Header="报警信息"
                                            Binding="{Binding Message}" Width="*" />
                        <DataGridTextColumn Header="级别"
                                            Binding="{Binding Level}" Width="80" />
                        <DataGridTextColumn Header="状态"
                                            Binding="{Binding State}" Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>