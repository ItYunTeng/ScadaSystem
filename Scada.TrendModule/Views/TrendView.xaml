<UserControl x:Class="Scada.TrendModule.Views.TrendView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wpf="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="#1EE546">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- 选择栏-->
        <Border Grid.Row="0" Background="#252526"
                BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4"
                Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="选择位号:" VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding AvailableTags}"
                          SelectedItem="{Binding SelectedTag}"
                          DisplayMemberPath="Name" Width="150"
                          Margin="0,0,20,0"/>
                <Button Content="开始记录" Command="{Binding
StartRecordCommand}" Background="#007ACC"
                        Foreground="White" Padding="15,5"
                        Margin="0,0,10,0" BorderThickness="0"/>
                <Button Content="停止记录" Command="{Binding
StopRecordCommand}" Background="#FF6B6B"
                        Foreground="White" Padding="15,5"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>
        <!-- 趋势图-->
        <Border Grid.Row="1" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4">
            <wpf:CartesianChart Series="{Binding Series}" LegendPosition="Right" AnimationsSpeed="00:00:00.300">
            </wpf:CartesianChart>
        </Border>
    </Grid>
</UserControl>